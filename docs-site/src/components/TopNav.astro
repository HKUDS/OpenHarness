---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 bg-white/80 dark:bg-gray-900/80 backdrop-blur border-b border-gray-200 dark:border-gray-800 flex items-center px-4 lg:px-6">
  <div class="flex items-center justify-between w-full max-w-screen-2xl mx-auto">
    <div class="flex items-center gap-3">
      <!-- Mobile sidebar toggle -->
      <button
        id="sidebar-toggle"
        type="button"
        class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition text-gray-600 dark:text-gray-300 lg:hidden"
        aria-label="Toggle sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <!-- Desktop sidebar collapse -->
      <button
        id="sidebar-collapse"
        type="button"
        class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition text-gray-600 dark:text-gray-300 hidden lg:flex items-center justify-center"
        aria-label="Collapse sidebar"
        aria-expanded="false"
      >
        <svg id="collapse-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="9" y1="3" x2="9" y2="21"></line>
        </svg>
        <svg id="collapse-icon-closed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="15" y1="3" x2="15" y2="21"></line>
          <line x1="9" y1="12" x2="15" y2="12"></line>
        </svg>
      </button>
      <a href="/docs/" class="flex items-center gap-2 no-underline">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold text-sm">OH</div>
        <span class="font-semibold text-gray-900 dark:text-white hidden sm:inline">OpenHarness</span>
        <span class="text-gray-400 hidden sm:inline">/</span>
        <span class="text-gray-500 text-sm hidden sm:inline">{title}</span>
      </a>
    </div>
    <nav class="flex items-center gap-3">
      <a href="/docs/" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition hidden md:inline">Home</a>
      <a href="/docs/user/getting-started/" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition hidden md:inline">User Guide</a>
      <a href="/docs/dev/architecture-overview/" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition hidden md:inline">Dev Docs</a>
      <div class="w-px h-5 bg-gray-300 dark:bg-gray-700 hidden md:block"></div>
      <!-- Simple button for theme toggle - controlled by inline JS -->
      <button
        id="theme-toggle-btn"
        type="button"
        class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition text-gray-600 dark:text-gray-300"
        aria-label="Switch theme"
        title="system"
      >
        <span class="theme-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </span>
      </button>
    </nav>
  </div>
</header>