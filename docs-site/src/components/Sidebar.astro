---
import { getCollection } from 'astro:content';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const allDocs = await getCollection('docs');

interface DocEntry {
  id: string;
  slug: string;
  data: { title?: string; description?: string };
}

interface TreeNode {
  label: string;
  href?: string;
  children?: TreeNode[];
  doc?: DocEntry;
}

const sectionOrder = ['user', 'dev'];
const subSectionOrder: Record<string, string[]> = {
  dev: ['core', 'infrastructure', 'ohmo', 'ui'],
};

const sectionLabels: Record<string, string> = {
  user: '用户手册',
  dev: '开发者文档',
  core: '核心模块',
  infrastructure: '基础设施',
  ohmo: 'ohmo 应用',
  ui: 'UI 层',
  root: '根目录',
};

function getDocTitle(doc: DocEntry): string {
  if (doc.data?.title) return doc.data.title;
  const name = doc.id.split('/').pop() || doc.id;
  return name.replace(/\.md$/, '').replace(/-/g, ' ');
}

function buildTree(docs: DocEntry[]): TreeNode[] {
  const root: TreeNode[] = [];

  // Add index doc at root
  const indexDoc = docs.find(d => d.id === 'index');
  if (indexDoc) {
    root.push({
      label: '首页',
      href: '/docs/',
      doc: indexDoc,
    });
  }

  for (const section of sectionOrder) {
    const sectionDocs = docs.filter(d => {
      const parts = d.id.split('/');
      return parts[0] === section;
    });

    if (sectionDocs.length === 0) continue;

    const node: TreeNode = {
      label: sectionLabels[section] || section,
      children: [],
    };

    const subSections = subSectionOrder[section] || [];

    // Check if there are sub-directories
    const hasSubDirs = sectionDocs.some(d => d.id.split('/').length > 2);

    if (hasSubDirs) {
      for (const sub of subSections) {
        const subDocs = sectionDocs.filter(d => {
          const parts = d.id.split('/');
          return parts.length > 1 && parts[1] === sub;
        });

        if (subDocs.length === 0) continue;

        const subNode: TreeNode = {
          label: sectionLabels[sub] || sub,
          children: subDocs.map(doc => ({
            label: getDocTitle(doc),
            href: `/docs/${doc.id.replace(/\.md$/, '')}/`,
            doc,
          })),
        };

        node.children!.push(subNode);
      }

      // Also add docs directly under section (not in a sub-dir)
      const directDocs = sectionDocs.filter(d => d.id.split('/').length === 2);
      for (const doc of directDocs) {
        node.children!.push({
          label: getDocTitle(doc),
          href: `/docs/${doc.id.replace(/\.md$/, '')}/`,
          doc,
        });
      }
    } else {
      node.children = sectionDocs.map(doc => ({
        label: getDocTitle(doc),
        href: `/docs/${doc.id.replace(/\.md$/, '')}/`,
        doc,
      }));
    }

    root.push(node);
  }

  return root;
}

const navTree = buildTree(allDocs);

function isOpen(node: TreeNode, path: string): boolean {
  if (node.href && (path === node.href || path === node.href?.replace(/\/$/, ''))) return true;
  if (node.children) {
    return node.children.some(child => isOpen(child, path));
  }
  return false;
}
---

<aside
  id="sidebar"
  class="fixed left-0 top-16 bottom-0 z-40 w-64 overflow-y-auto bg-gray-50 dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 py-4 px-3 transition-all duration-200 lg:translate-x-0 -translate-x-full"
>
  <nav class="space-y-1">
    {navTree.map(node => {
      const hasChildren = node.children && node.children.length > 0;
      const nodeOpen = isOpen(node, currentPath);

      if (!hasChildren && node.href) {
        // Leaf node at root level
        const isActive = currentPath === node.href || currentPath === node.href.replace(/\/$/, '');
        return (
          <a
            href={node.href}
            class={`flex items-center gap-2 px-3 py-2 rounded-md text-sm transition ${
              isActive
                ? 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 font-medium'
                : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800'
            }`}
          >
            <span class="truncate">{node.label}</span>
          </a>
        );
      }

      return (
        <div class="sidebar-section" data-open={nodeOpen ? 'true' : 'false'}>
          <button
            type="button"
            class="sidebar-section-toggle flex items-center justify-between w-full px-3 py-2 rounded-md text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider hover:bg-gray-100 dark:hover:bg-gray-800 transition"
            aria-expanded={nodeOpen ? 'true' : 'false'}
          >
            <span>{node.label}</span>
            <svg class="sidebar-chevron w-4 h-4 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
            </svg>
          </button>
          <div class={`sidebar-section-content ${nodeOpen ? '' : 'hidden'}`}>
            <ul class="space-y-0.5 pl-2 mt-1">
              {node.children!.map(child => {
                const childHasChildren = child.children && child.children.length > 0;
                const childOpen = isOpen(child, currentPath);

                if (childHasChildren) {
                  return (
                    <li class="sidebar-section" data-open={childOpen ? 'true' : 'false'}>
                      <button
                        type="button"
                        class="sidebar-section-toggle flex items-center justify-between w-full px-3 py-1.5 rounded-md text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider hover:bg-gray-100 dark:hover:bg-gray-800 transition"
                        aria-expanded={childOpen ? 'true' : 'false'}
                      >
                        <span>{child.label}</span>
                        <svg class="sidebar-chevron w-3 h-3 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                        </svg>
                      </button>
                      <div class={`sidebar-section-content ${childOpen ? '' : 'hidden'}`}>
                        <ul class="space-y-0.5 pl-3 mt-1">
                          {child.children!.map(leaf => {
                            const isActive = currentPath === leaf.href || currentPath === leaf.href?.replace(/\/$/, '');
                            return (
                              <li>
                                <a
                                  href={leaf.href}
                                  class={`block px-3 py-1.5 rounded-md text-sm transition ${
                                    isActive
                                      ? 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 font-medium'
                                      : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800'
                                  }`}
                                >
                                  {leaf.label}
                                </a>
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    </li>
                  );
                }

                const isActive = currentPath === child.href || currentPath === child.href?.replace(/\/$/, '');
                return (
                  <li>
                    <a
                      href={child.href}
                      class={`block px-3 py-1.5 rounded-md text-sm transition ${
                        isActive
                          ? 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 font-medium'
                          : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800'
                      }`}
                    >
                      {child.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      );
    })}
  </nav>
</aside>

<!-- Mobile sidebar overlay -->
<div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden" aria-hidden="true"></div>
